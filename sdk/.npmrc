# Publish/consume @fps4/* from GitHub Packages (fps4 org). Auth is read from NODE_AUTH_TOKEN. In CI the
# publish-sdk workflow supplies the built-in GITHUB_TOKEN (packages:write). Never commit a token; only
# this env reference is committed. Non-@fps4 deps still resolve from the default registry.
@fps4:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
