# The identity-service management API base URL (server-side only — never exposed to the browser).
ADMIN_API_URL=http://localhost:7305/admin/v1

# --- Operator login (RQ-0007, ADR-0010) — the per-actor path ---
# Where the browser runs the OAuth `password` grant to sign an operator in. This is the identity-service
# ROOT (not /admin/v1). NEXT_PUBLIC_* so the client bundle can reach the token endpoint directly.
NEXT_PUBLIC_IDENTITY_SERVICE_BASE=http://localhost:7305
# The OAuth client the console logs operators in as (a dedicated, password-grant client on the operator
# tenant). The operator user must carry an operator role (default `platform_admin` — ADMIN_OPERATOR_ROLES
# on the service) so the management plane accepts their token (ADR-0010).
NEXT_PUBLIC_IDENTITY_SERVICE_CLIENT_ID=identity-console

# --- Break-glass / non-interactive fallback (NOT per-actor) ---
# A client-credentials access token carrying the `admin` scope. Used ONLY when there is no operator
# session (bootstrap, scripts, recovery). When an operator is signed in, the console forwards THEIR token
# instead, so the action is audited against the human. Leave blank to require operator login.
#   curl -s -XPOST $ISSUER/oauth2/token -d grant_type=client_credentials \
#        -d client_id=$ADMIN_CLIENT_ID -d client_secret=$ADMIN_CLIENT_SECRET -d scope=admin | jq -r .access_token
ADMIN_API_TOKEN=
