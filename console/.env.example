# The identity-service management API base URL (server-side only — never exposed to the browser).
ADMIN_API_URL=http://localhost:7305/admin/v1

# A client-credentials access token carrying the `admin` scope. The console calls the API server-side
# with this bearer token, so the secret never reaches the browser. Obtain it from an admin OAuth client:
#   curl -s -XPOST $ISSUER/oauth2/token -d grant_type=client_credentials \
#        -d client_id=$ADMIN_CLIENT_ID -d client_secret=$ADMIN_CLIENT_SECRET -d scope=admin | jq -r .access_token
# (Tokens expire — in production, mint/refresh this from the client id+secret rather than pasting a token.)
ADMIN_API_TOKEN=
