PORT=7305
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=component-auth
AUTH_JWT_SECRET=replace-me
AUTH_JWT_ISSUER=component-auth-service # HTTPS base for your deployment, i.e. https://auth.yourdomain.com
AUTH_JWT_AUDIENCE=component-auth-clients
SESSION_TTL_MINUTES=15

# Local-credential IdP (RQ-0002): password policy + brute-force lockout
AUTH_PASSWORD_MIN_LENGTH=10
AUTH_PASSWORD_MAX_ATTEMPTS=5
AUTH_PASSWORD_LOCKOUT_MINUTES=15
AUTH_REGISTRATIONS_PER_MINUTE=20      # per-tenant self-service registration rate limit
OAUTH_ACCESS_TOKEN_TTL_SEC=900        # user + machine access token TTL (15m)
OAUTH_REFRESH_TOKEN_TTL_SEC=2592000   # user refresh token TTL (30d); rotates on use (RQ-0001)
OAUTH_AUTHORIZATION_TTL_SEC=600       # login authorization record / auth-code lifetime (10m)
OAUTH_CLIENT_CREDENTIALS_SCOPE=
OAUTH_TENANT_MAX_CLIENTS=50
OAUTH_TENANT_MAX_TOKENS_PER_MINUTE=200
OAUTH_TENANT_MAX_REFRESH_TOKENS=10000
OAUTH_KEY_PASSPHRASE=                 # REQUIRED in deployed envs — encrypts signing keys at rest (AES-256-GCM)
OAUTH_KEY_ROTATION_HOURS=720

# Google OIDC upstream (RQ-0001 user login). Register this service's callback as an authorized
# redirect URI on the Google app, e.g. https://auth-dev.example.com/oauth2/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://auth-dev.example.com/oauth2/callback
# Endpoints below default to Google's real ones; override only for testing/staging.
GOOGLE_ISSUER=https://accounts.google.com
GOOGLE_AUTHORIZATION_ENDPOINT=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token
GOOGLE_JWKS_URI=https://www.googleapis.com/oauth2/v3/certs
CORS_ORIGINS=
TENANT_CORS_REFRESH_INTERVAL_MS=300000
LOG_LEVEL=info
LOG_PRETTY=true
